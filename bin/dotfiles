#!/bin/bash

# =============================================================================
# Script Name : dotfiles
# Description : Simple CLI interface for managing dotfiles configuration
# =============================================================================

set -e

# Find dotfiles root directory
DOTFILES_ROOT="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"

# Source utility functions
source "$DOTFILES_ROOT/lib/detect.sh"
source "$DOTFILES_ROOT/lib/symlink.sh"

# Command router
main() {
    local command="${1:-setup}"
    local target="${2:-}"
    
    case "$command" in
        setup)     handle_setup "$target" ;;
        link)      handle_link "$target" ;;
        unlink)    handle_unlink "$target" ;;
        clean)     handle_clean ;;
        edit)      handle_edit "$target" ;;
        status)    handle_status ;;
        *)         echo "Usage: dotfiles [setup|link|unlink|clean|edit|status] [target|all]" && exit 1 ;;
    esac
}

handle_setup() {
    local target="$1"
    local os="$(detect_os)"
    
    log_info "Setting up $os environment..."
    
    # Always run OS installer
    local os_installer="$DOTFILES_ROOT/os/$os/install.sh"
    if [[ -f "$os_installer" ]]; then
        source "$os_installer"
    else
        log_warn "No OS installer found for: $os"
    fi
    
    # Link configs if specified
    if [[ -n "$target" ]]; then
        create_single_symlink "$target" "$os"
    else
        create_all_symlinks "$os"
    fi
    
    log_success "Setup completed!"
}

handle_link() {
    local target="$1"
    local os="$(detect_os)"
    
    # Default to 'all' behavior when no args
    if [[ -z "$target" || "$target" == "all" ]]; then
        create_all_symlinks "$os"
    else
        create_single_symlink "$target" "$os"
    fi
}

handle_unlink() {
    local target="$1"
    local os="$(detect_os)"
    
    # Default to 'all' behavior when no args
    if [[ -z "$target" || "$target" == "all" ]]; then
        remove_symlinks "$os"
    else
        remove_single_config "$target" "$os"
    fi
}

handle_clean() {
    clean_broken_symlinks
}

handle_edit() {
    local target="$1"
    
    # Check if EDITOR is set
    if [[ -z "$EDITOR" ]]; then
        log_error "\$EDITOR environment variable is not set"
        echo "Please set your editor preference:"
        echo "  export EDITOR=nvim      # For Neovim"
        echo "  export EDITOR=vim       # For Vim"
        echo "  export EDITOR=code      # For VS Code"
        echo "  export EDITOR=nano      # For Nano"
        exit 1
    fi
    
    # If no config specified, open entire dotfiles directory
    if [[ -z "$target" ]]; then
        log_info "Opening dotfiles directory in $EDITOR..."
        exec "$EDITOR" "$DOTFILES_ROOT"
    fi
    
    # Find config path
    local os="$(detect_os)"
    local config_path="$(resolve_config_path "$target" "$os")"
    
    if [[ -z "$config_path" ]]; then
        log_error "Configuration '$target' not found"
        echo "Available configurations:"
        show_list "$os"
        exit 1
    fi
    
    local full_path="$DOTFILES_ROOT/$config_path"
    log_info "Opening $target configuration in $EDITOR..."
    log_info "Path: $full_path"
    exec "$EDITOR" "$full_path"
}

handle_status() {
    show_status "$(detect_os)"
}

# Make sure all lib scripts are executable
chmod +x "$DOTFILES_ROOT"/lib/*.sh
chmod +x "$DOTFILES_ROOT"/os/*/install.sh

# Run main function with all arguments
main "$@"